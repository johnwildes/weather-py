# Ignore Python bytecode and cache files
__pycache__/
*.py[cod]

# Ignore virtual environment folders
venv/
.env/

# VS Code - ignore user-specific settings but allow shared configs (extensions, launch, tasks)
.vscode/settings.json
.vscode/*.code-workspace

# Ignore environment variables file
.env

# Ignore logs and temporary files
*.log
*.tmp

# Ignore Python egg files
*.egg
*.egg-info/


build/

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/
# Ignore Node.js dependencies
node_modules/

# .NET build artifacts
bin/
obj/
out/
publish/

# .NET NuGet
*.nupkg
*.snupkg
packages/
.nuget/

# .NET user/local files
*.user
*.suo
*.userosscache
*.userprefs

# Visual Studio local cache/settings
.vs/

# .NET test results & coverage
TestResults/
coverage/
*.coverage
*.coveragexml
*.trx
BenchmarkDotNet.Artifacts/

# .NET secrets (use Secret Manager instead)
**/secrets.json
**/appsettings.Development.json

# Blazor/WASM specific
**/wwwroot/lib/
